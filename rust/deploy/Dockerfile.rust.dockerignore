# Context is the repo root (see docker-compose.yml). The Rust image only needs
# `rust/` (workspace) and `mlflow/version.py`; exclude everything else so the
# build context stays small. BuildKit reads this file because it is named
# `<dockerfile>.dockerignore` next to the referenced Dockerfile.
*
!rust/
!mlflow/version.py
!mlflow/protos/
!mlflow/server/js/src/graphql/autogenerated_schema.gql

# Within the kept `rust/` tree, drop build/scratch artifacts.
rust/target/
rust/spikes/
**/.git
