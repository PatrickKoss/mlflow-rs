{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mlflow.org/schemas/rust-bench-genai-raw-metrics-1.2.0.json",
  "title": "MLflow Phase 23 GenAI raw benchmark metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "summary",
    "requests",
    "jobs",
    "resources",
    "db_pool",
    "provider",
    "equivalence"
  ],
  "properties": {
    "schema_version": {"enum": ["1.0.0", "1.1.0", "1.2.0"]},
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "workload", "seed", "concurrency", "warmup_requests", "started_at", "finished_at"],
      "properties": {
        "target": {"enum": ["python", "rust"]},
        "workload": {"type": "string"},
        "seed": {"type": "integer"},
        "concurrency": {"type": "integer", "minimum": 1},
        "db_pool_config": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pool_size", "max_overflow", "postgres_max_connections"],
          "properties": {
            "pool_size": {"type": "integer", "minimum": 1},
            "max_overflow": {"type": "integer", "minimum": 0},
            "postgres_max_connections": {"type": "integer", "minimum": 1}
          }
        },
        "warmup_requests": {"type": "integer", "minimum": 0},
        "started_at": {"type": "string", "format": "date-time"},
        "finished_at": {"type": "string", "format": "date-time"},
        "family": {"type": "string"},
        "payload_size": {"enum": ["small", "large"]},
        "mix": {"enum": ["write-heavy", "read-heavy"]},
        "measured_requests": {"type": "integer", "minimum": 1},
        "canonical_requests": {"type": "integer", "minimum": 1},
        "large_definition": {"type": "string"},
        "shape": {"enum": ["high-fanout", "large-payload", "burst", "steady-drip"]},
        "job_kinds": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "canonical_jobs": {"type": "integer", "minimum": 1},
        "measured_jobs": {"type": "integer", "minimum": 1},
        "post_completion_settle_seconds": {"type": "number", "minimum": 0},
        "rows_per_job": {"type": "integer", "minimum": 1},
        "issue_disjoint_corpus": {"type": "boolean"},
        "concurrent_terminal_polling": {"type": "boolean"},
        "steady_drip_interleaved": {"type": "boolean"},
        "trimmed": {"type": "boolean"},
        "trim_note": {"type": ["string", "null"]}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoints", "overall"],
      "properties": {
        "endpoints": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/endpointSummary"}
        },
        "overall": {
          "type": "object",
          "additionalProperties": false,
          "required": ["duration_seconds", "requests", "errors", "error_rate", "rps"],
          "properties": {
            "duration_seconds": {"type": "number", "minimum": 0},
            "requests": {"type": "integer", "minimum": 0},
            "errors": {"type": "integer", "minimum": 0},
            "error_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "rps": {"type": "number", "minimum": 0},
            "latency_ms": {"$ref": "#/$defs/percentiles"},
            "jobs_per_minute": {"type": "number", "minimum": 0},
            "job_kinds": {"type": "object"},
            "fairness": {"type": ["object", "null"]},
            "resources": {
              "type": "object",
              "additionalProperties": false,
              "required": ["cpu_seconds", "mean_rss_mib", "peak_rss_mib"],
              "properties": {
                "cpu_seconds": {"type": "number", "minimum": 0},
                "mean_rss_mib": {"type": "number", "minimum": 0},
                "peak_rss_mib": {"type": "number", "minimum": 0}
              }
            }
          }
        }
      }
    },
    "requests": {"type": "array", "items": {"$ref": "#/$defs/request"}},
    "jobs": {"type": "array", "items": {"$ref": "#/$defs/job"}},
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "samples"],
      "properties": {
        "method": {"type": "string"},
        "samples": {"type": "array", "items": {"$ref": "#/$defs/resourceSample"}}
      }
    },
    "db_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "samples"],
      "properties": {
        "method": {"type": "string"},
        "samples": {"type": "array", "items": {"$ref": "#/$defs/poolSample"}}
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed", "url", "route_latency_ms", "observations"],
      "properties": {
        "seed": {"type": "integer"},
        "url": {"type": "string"},
        "route_latency_ms": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0}
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["route", "request_sha256", "response_sha256", "response_bytes"],
            "properties": {
              "route": {"type": "string"},
              "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "response_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "response_bytes": {"type": "integer", "minimum": 0}
            }
          }
        }
      }
    },
    "leak_check": {"type": "object"},
    "machine_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "load_average", "pids_current", "process_count", "target_tree_pids", "matching_processes"],
      "properties": {
        "timestamp": {"type": "string", "format": "date-time"},
        "load_average": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}], "items": false},
        "pids_current": {"type": ["integer", "null"], "minimum": 0},
        "process_count": {"type": "integer", "minimum": 0},
        "target_tree_pids": {"type": "array", "items": {"type": "integer", "minimum": 1}},
        "matching_processes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pid", "command"],
            "properties": {"pid": {"type": "integer", "minimum": 1}, "command": {"type": "string"}}
          }
        }
      }
    },
    "equivalence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_seed", "samples", "jobs"],
      "properties": {
        "sample_seed": {"type": "integer"},
        "samples": {"type": "array", "items": {"type": "object"}},
        "jobs": {"type": "array", "items": {"$ref": "#/$defs/job"}},
        "verdict": {"enum": ["PENDING", "PASS", "FAIL"]}
      }
    }
  },
  "$defs": {
    "percentiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p50", "p95", "p99", "max"],
      "properties": {
        "p50": {"type": ["number", "null"]},
        "p95": {"type": ["number", "null"]},
        "p99": {"type": ["number", "null"]},
        "max": {"type": ["number", "null"]}
      }
    },
    "endpointSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "errors", "error_rate", "rps", "latency_ms", "statuses", "sse"],
      "properties": {
        "requests": {"type": "integer", "minimum": 0},
        "errors": {"type": "integer", "minimum": 0},
        "error_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "rps": {"type": "number", "minimum": 0},
        "latency_ms": {"$ref": "#/$defs/percentiles"},
        "statuses": {"type": "object", "additionalProperties": {"type": "integer"}},
        "sse": {
          "type": "object",
          "additionalProperties": false,
          "required": ["streams", "time_to_first_event_ms", "inter_frame_gap_ms"],
          "properties": {
            "streams": {"type": "integer", "minimum": 0},
            "time_to_first_event_ms": {"$ref": "#/$defs/percentiles"},
            "inter_frame_gap_ms": {"$ref": "#/$defs/percentiles"}
          }
        }
      }
    },
    "sse": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["frame_count", "time_to_first_event_ms", "inter_frame_gap_ms", "frame_elapsed_ms", "frames"],
      "properties": {
        "frame_count": {"type": "integer", "minimum": 0},
        "time_to_first_event_ms": {"type": ["number", "null"]},
        "inter_frame_gap_ms": {"type": "array", "items": {"type": "number"}},
        "frame_elapsed_ms": {"type": "array", "items": {"type": "number"}},
        "frames": {"type": "array", "items": {"type": "string"}}
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "endpoint", "method", "path", "status", "latency_ms", "error", "response", "sse"],
      "properties": {
        "sequence": {"type": "integer"},
        "endpoint": {"type": "string"},
        "method": {"type": "string"},
        "path": {"type": "string"},
        "status": {"type": ["integer", "null"]},
        "latency_ms": {"type": "number", "minimum": 0},
        "error": {"type": ["string", "null"]},
        "response": {},
        "request_bytes": {"type": ["integer", "null"], "minimum": 0},
        "sse": {"$ref": "#/$defs/sse"}
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "status", "result", "status_details", "polls", "queue_wait_seconds", "execution_seconds", "submit_to_terminal_seconds"],
      "properties": {
        "job_id": {"type": "string"},
        "status": {"type": "string"},
        "result": {},
        "status_details": {},
        "polls": {"type": "integer", "minimum": 1},
        "queue_wait_seconds": {"type": "number", "minimum": 0},
        "execution_seconds": {"type": "number", "minimum": 0},
        "submit_to_terminal_seconds": {"type": "number", "minimum": 0},
        "api_creation_time_ms": {"type": ["integer", "null"], "minimum": 0},
        "api_last_update_time_ms": {"type": ["integer", "null"], "minimum": 0},
        "job_kind": {"type": "string"},
        "sequence": {"type": "integer", "minimum": 0},
        "result_sampled": {"type": "boolean"},
        "timed_out": {"type": "boolean"},
        "submitted_offset_seconds": {"type": "number", "minimum": 0},
        "terminal_offset_seconds": {"type": "number", "minimum": 0}
      }
    },
    "resourceSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "elapsed_seconds", "rss_bytes", "process_count", "utime_seconds", "stime_seconds"],
      "properties": {
        "timestamp": {"type": "string", "format": "date-time"},
        "elapsed_seconds": {"type": "number", "minimum": 0},
        "rss_bytes": {"type": "integer", "minimum": 0},
        "process_count": {"type": "integer", "minimum": 0},
        "thread_count": {"type": "integer", "minimum": 0},
        "utime_seconds": {"type": "number", "minimum": 0},
        "stime_seconds": {"type": "number", "minimum": 0}
      }
    },
    "poolSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elapsed_seconds", "total", "active", "waiting", "source"],
      "properties": {
        "elapsed_seconds": {"type": "number", "minimum": 0},
        "total": {"type": "integer", "minimum": 0},
        "active": {"type": "integer", "minimum": 0},
        "waiting": {"type": "integer", "minimum": 0},
        "source": {"type": "string"}
      }
    }
  }
}
